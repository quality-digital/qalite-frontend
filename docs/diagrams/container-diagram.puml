@startuml
!theme plain
actor User
node "Navegador" {
  component "React SPA" as SPA
  component "Contexts/Hooks" as State
  component "Services/Repositories" as Services
}
cloud "Firebase" {
  component "Auth" as Auth
  database "Firestore" as Firestore
  folder "Storage" as Storage
}
cloud "Slack Webhook" as Slack

User --> SPA
SPA --> State
State --> Services
Services --> Auth
Services --> Firestore
Services --> Storage
Services --> Slack
@enduml
