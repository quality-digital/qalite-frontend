@startuml
!theme plain
node "Hospedagem estática\n(Vercel configurado por vercel.json)" as Hosting {
  artifact "dist/" as Dist
}
node "Cliente" as Client {
  node "Browser" as Browser
}
cloud "Firebase Project" as Firebase {
  component "Auth"
  database "Firestore"
  folder "Storage"
}
cloud "Slack" as Slack

Browser --> Dist : baixa HTML/JS/CSS
Browser --> Firebase : SDK Firebase
Browser --> Slack : fetch para webhook
@enduml
