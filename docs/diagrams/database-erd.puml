@startuml
!theme plain
entity "users" as users {
  * uid : string
  --
  email : string
  displayName : string
  role : admin|user
  organizationId : string?
  preferences : object
  browserstackCredentials : object?
}
entity "organizations" as orgs {
  * id : string
  --
  name : string
  emailDomain : string?
  slackWebhookUrl : string?
  memberIds : string[]
}
entity "accessRequests" as access {
  * userId : string
  --
  organizationId : string
  email : string
  displayName : string
}
entity "stores" as stores {
  * id : string
  --
  organizationId : string
  name : string
  environmentColumns : string[]
  scenarioCount : number
}
entity "scenarios" as scenarios {
  * id : string
  --
  storeId : string
  title : string
  category : string
  automation : string
  criticality : string
}
entity "suites" as suites {
  * id : string
  --
  storeId : string
  scenarioIds : string[]
}
entity "categories" as categories {
  * id : string
  --
  storeId : string
  name : string
  searchName : string
}
entity "environments" as envs {
  * id : string
  --
  storeId : string
  suiteId : string?
  status : backlog|in_progress|done
  scenarios : map
  participants : string[]
}

orgs ||--o{ users : organizationId
orgs ||--o{ access : contains
orgs ||--o{ stores : organizationId
stores ||--o{ scenarios : subcollection
stores ||--o{ suites : subcollection
stores ||--o{ categories : subcollection
stores ||--o{ envs : storeId
@enduml
